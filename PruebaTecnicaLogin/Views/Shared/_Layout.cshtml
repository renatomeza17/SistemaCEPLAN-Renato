<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CEPLAN - Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <header class="gob-header">
        <div class="container d-flex justify-content-between">
            <img class="logo-ceplan" src="~/images/logo-ceplan.svg">
            <div>?</div>
        </div>
    </header>

    <div class="container mt-4">
        @RenderBody()
    </div>


    <footer class="footer-institucional">
    <div class="container-fluid d-flex justify-content-end align-items-center">
        <img src="~/images/logo-ministerio.png" alt="Logos" style="height: 45px;" />
    </div>
    </footer>

    <div class="modal fade" id="modalExpiracion" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-warning rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-exclamation-triangle-fill text-white fs-4"></i>
                    </div>
                    <h5 class="modal-title fw-bold">Su sesión está a punto de expirar</h5>
                </div>
                <p class="text-muted">Por seguridad, su sesión expirará en <span id="segundosRestantes" class="fw-bold text-dark">49</span> segundos. Para continuar, seleccione "Extender sesión".</p>
                <div class="d-flex justify-content-end mt-4">
                    <button type="button" class="btn btn-warning text-white fw-bold px-4" id="btnExtender" style="background-color: #b38600; border: none; border-radius: 8px;">
                        Extender sesión
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @using Microsoft.AspNetCore.Http
    @inject IHttpContextAccessor HttpContextAccessor


    @if (HttpContextAccessor.HttpContext.Session.GetString("UsuarioCorreo") != null)
    {
        <script src="~/js/site.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>