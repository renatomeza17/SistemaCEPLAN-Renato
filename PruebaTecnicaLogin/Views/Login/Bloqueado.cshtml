@{
    Layout = "_Layout";
}

<div class="confirm-container" style="background: url('/images/fondo_peru.png') no-repeat center center fixed; background-size: cover; min-height: 90vh; display: flex; align-items: center; justify-content: center;">
    
    <div class="card p-5 text-center shadow-sm" style="width: 500px; border-radius: 15px; border: none;">
        <div class="mb-4">
             <img src="~/images/user.svg" style="width: 100px;" />
        </div>
        
        <h3 class="fw-bold mb-3" style="color: #333;">Cuenta bloqueada temporalmente</h3>
        
        <p class="text-muted" style="font-size: 0.95rem; line-height: 1.6;">
            Has excedido el número máximo de intentos fallidos (5). 
            Por seguridad, tu cuenta ha sido bloqueada durante <strong>20 minutos</strong>. 
            Intenta nuevamente más tarde.
        </p>

        <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2 mt-4" style="border-radius: 25px;">
            Regresar al inicio
        </a>
    </div>

    <div style="position: fixed; bottom: 20px; right: 20px;">
        <img src="~/images/logos_footer.png" style="height: 50px;" />
    </div>
</div>