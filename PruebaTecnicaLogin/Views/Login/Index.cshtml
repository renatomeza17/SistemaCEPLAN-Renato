@model PruebaTecnicaLogin.Models.Usuario
@{
    Layout = "_Layout"; 
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card login-card p-4">
            @if (Context.Request.Query["mensaje"] == "expirado")
            {
                <div class="alert alert-warning text-center py-2 mb-3" style="font-size: 0.85rem;">
                    <i class="bi bi-exclamation-triangle-fill"></i> Su sesión ha expirado por inactividad.
                </div>
            }

            <h3 class="text-center mb-4 text-secondary">Gestión de usuarios</h3>

            <ul class="nav nav-tabs nav-tabs-custom justify-content-center mb-4">
                <li class="nav-item">
                    <a class="nav-link active" href="#">DNI</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">CE</a>
                </li>
            </ul>

            <form asp-controller="Login" asp-action="Acceder" method="post">
                <div class="mb-3">
                    <label class="form-label text-muted">Usuario</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-person"></i></span>
                        <input type="email" name="correo" class="form-control border-start-0" placeholder="Ingresar usuario" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted">Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-lock"></i></span>
                        <input type="password" name="clave" class="form-control border-start-0" placeholder="Ingresar contraseña" required />
                    </div>
                </div>

                <div class="text-end mb-3">
                    <a href="#" class="text-decoration-none small text-muted">¿Olvidó su contraseña?</a>
                </div>

                <button type="submit" class="btn btn-primary btn-login w-100">Ingresar</button>
            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3 py-2 small text-center">
                    @ViewBag.Error
                </div>
            }

            <div class="text-center mt-4 pt-3 border-top">
                <small class="text-muted">
                    <i class="bi bi-headset"></i> ¿Necesita ayuda?, contacte con el área de soporte
                </small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/login.js"></script>
}