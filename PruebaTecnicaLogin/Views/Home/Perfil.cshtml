@{
    Layout = "_Layout";
}

<div class="d-flex" style="min-height: 92vh; background-color: #F4F7F9;">
    <div class="bg-white border-end d-flex flex-column align-items-center py-3" style="width: 70px;">
        <i class="bi bi-list fs-3 mb-4 text-secondary"></i>
        <i class="bi bi-grid-fill fs-4 mb-4 text-secondary"></i>
        <i class="bi bi-person-badge fs-4 mb-4 text-secondary"></i>
        <div class="bg-danger-subtle p-2 rounded mb-4">
            <i class="bi bi-file-earmark-text-fill fs-4 text-danger"></i>
        </div>
        <i class="bi bi-gear fs-4 text-secondary"></i>
    </div>

    <div class="flex-grow-1 p-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb" style="font-size: 0.8rem;">
                <li class="breadcrumb-item text-primary">Perfil de usuario</li>
            </ol>
        </nav>

        <h3 class="fw-bold mb-4">Perfil de usuario</h3>

        <div class="card border-0 shadow-sm p-4" style="border-radius: 12px;">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 70px; height: 70px; font-size: 1.8rem;">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div class="ms-3">
                    <h5 class="mb-0 fw-bold">Mendoza Quispe, July Camila <span class="badge bg-success-subtle text-success ms-2 fw-normal" style="font-size: 0.7rem;">Activo</span></h5>
                    <p class="text-muted small mb-0">Administrador de Recursos</p>
                    <small class="text-secondary" style="font-size: 0.75rem;">011 Ministerio de Salud</small>
                </div>
            </div>

            <ul class="nav nav-tabs border-0 mb-4" style="font-size: 0.9rem;">
                <li class="nav-item">
                    <a class="nav-link active border-0 border-bottom border-primary border-3 fw-bold" href="#">Información básica</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-muted border-0" href="#">Responsabilidades</a>
                </li>
            </ul>

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label text-muted small">Nombres</label>
                    <input type="text" class="form-control bg-light border-0" value="July Camila" readonly>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted small">Primer Apellido</label>
                    <input type="text" class="form-control bg-light border-0" value="Mendoza" readonly>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted small">Segundo Apellido</label>
                    <input type="text" class="form-control bg-light border-0" value="Quispe" readonly>
                </div>
            </div>
        </div>
    </div>


</div>